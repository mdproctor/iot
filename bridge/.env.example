# ═══════════════════════════════════════════════════════════════════════════
# CaseHub IoT Bridge — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in your values before running `docker compose up`.
#

# ───────────────────────────────────────────────────────────────────────────
# Bridge Agent — Cloud Connection
# ───────────────────────────────────────────────────────────────────────────

# Tenancy ID for multi-tenant cloud deployments
CASEHUB_IOT_TENANCY_ID=default

# WebSocket endpoint for cloud connection
CASEHUB_IOT_BRIDGE_CLOUD_ENDPOINT=wss://cloud.example.com/iot/bridge

# Authentication token for bridge → cloud connection
CASEHUB_IOT_BRIDGE_TOKEN=changeme

# Reconnect backoff — base delay in seconds (default: 5)
# CASEHUB_IOT_BRIDGE_RECONNECT_BASE_SECONDS=5

# Reconnect backoff — max delay in seconds (default: 300)
# CASEHUB_IOT_BRIDGE_RECONNECT_MAX_SECONDS=300

# Heartbeat interval in seconds (default: 30)
# CASEHUB_IOT_BRIDGE_HEARTBEAT_INTERVAL_SECONDS=30

# ───────────────────────────────────────────────────────────────────────────
# Event Store — Persistent Queue
# ───────────────────────────────────────────────────────────────────────────

# Max events in persistent store (default: 10000)
# CASEHUB_IOT_BRIDGE_EVENT_STORE_MAX_SIZE=10000

# Event store directory (default: data/bridge-events)
# CASEHUB_IOT_BRIDGE_EVENT_STORE_DIRECTORY=data/bridge-events

# ───────────────────────────────────────────────────────────────────────────
# Home Assistant Provider
# ───────────────────────────────────────────────────────────────────────────

# Enable Home Assistant integration (default: false)
CASEHUB_IOT_HOMEASSISTANT_ENABLED=true

# Long-lived access token from Home Assistant (Profile → Security)
CASEHUB_IOT_HOMEASSISTANT_TOKEN=your-ha-long-lived-access-token

# Home Assistant URL — leave commented for auto-discovery via mDNS
# CASEHUB_IOT_HOMEASSISTANT_URL=http://192.168.1.100:8123

# WebSocket reconnect — base delay in seconds (default: 5)
# CASEHUB_IOT_HOMEASSISTANT_RECONNECT_BASE_SECONDS=5

# WebSocket reconnect — max delay in seconds (default: 300)
# CASEHUB_IOT_HOMEASSISTANT_RECONNECT_MAX_SECONDS=300

# WebSocket ping interval in seconds (default: 30)
# CASEHUB_IOT_HOMEASSISTANT_PING_INTERVAL_SECONDS=30

# WebSocket pong timeout in seconds (default: 10)
# CASEHUB_IOT_HOMEASSISTANT_PONG_TIMEOUT_SECONDS=10

# mDNS discovery timeout in seconds (default: 5)
# CASEHUB_IOT_HOMEASSISTANT_DISCOVERY_TIMEOUT_SECONDS=5

# ───────────────────────────────────────────────────────────────────────────
# OpenHAB Provider
# ───────────────────────────────────────────────────────────────────────────

# Enable OpenHAB integration (default: false)
# CASEHUB_IOT_OPENHAB_ENABLED=true

# OpenHAB API token (Settings → API Security → Add API Token)
# CASEHUB_IOT_OPENHAB_AUTH_BEARER_TOKEN=your-openhab-api-token

# OpenHAB URL — leave commented for auto-discovery via mDNS + SSDP
# CASEHUB_IOT_OPENHAB_URL=http://192.168.1.101:8080

# Alternative: Basic auth (uncomment both if using instead of bearer token)
# CASEHUB_IOT_OPENHAB_AUTH_BASIC_USERNAME=admin
# CASEHUB_IOT_OPENHAB_AUTH_BASIC_PASSWORD=your-password

# SSE reconnect — base delay in seconds (default: 5)
# CASEHUB_IOT_OPENHAB_RECONNECT_BASE_SECONDS=5

# SSE reconnect — max delay in seconds (default: 300)
# CASEHUB_IOT_OPENHAB_RECONNECT_MAX_SECONDS=300

# Event coalescing window in milliseconds (default: 50)
# CASEHUB_IOT_OPENHAB_COALESCE_WINDOW_MS=50

# Enable Thing-level discovery (default: true)
# CASEHUB_IOT_OPENHAB_THING_DISCOVERY_ENABLED=true

# mDNS/SSDP discovery timeout in seconds (default: 10)
# CASEHUB_IOT_OPENHAB_DISCOVERY_TIMEOUT_SECONDS=10
